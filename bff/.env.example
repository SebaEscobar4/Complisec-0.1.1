# ── Producción (Render/Railway) ──────────────────────────────────────────
# La mayoría de proveedores exponen una sola cadena de conexión a Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Si la base lo requiere SSL (normal en hosts gestionados), déjalo así.
# Si NO requiere SSL, agrega: DB_SSL=false

DATABASE_URL=
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ── Email (opcional — sin esto, los códigos se imprimen en los logs) ─────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CompliSec <no-reply@complisec.com>

# ── Desarrollo local sin Docker (usar en vez de DATABASE_URL) ────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=complisec_user
# DB_PASSWORD=complisec_password
# DB_NAME=complisec
# PORT=4000
